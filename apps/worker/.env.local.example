# ── worker ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=queue_db
DB_USER=postgres
DB_PASS=postgres

# ── Queue tuning (opcional, valores por defecto en paréntesis) ──────────────────
# Tiempo máximo que un job puede estar en 'processing' antes de considerarse stale. Default: 300000 (5 min)
QUEUE_STALE_JOB_TIMEOUT_MS=300000
# Cada cuánto el recovery busca jobs stale. Default: 30000 (30 seg)
QUEUE_STALE_JOB_CHECK_INTERVAL_MS=30000
# Máximo de reintentos por job. Default: 3
QUEUE_MAX_RETRIES=3
# Conexiones a PG por instancia del worker (controla su concurrencia de procesamiento). Default: 20
QUEUE_MAX_CONNECTIONS=20
# Identificador de esta instancia worker (se persiste en jobs."workerId" al capturar). Default: hostname del host
# WORKER_ID=worker-local-1
