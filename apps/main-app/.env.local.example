# ── main-app ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=queue_db
DB_USER=postgres
DB_PASS=postgres

# ── Queue request/reply ─────────────────────────────────────────────────────────
# Timeout del endpoint GET /jobs/sync esperando la response del worker. Default: 30000
QUEUE_REQUEST_TIMEOUT_MS=30000
# Tamaño máx. de los pools del productor (TypeORM enqueue + reply waiter). Default: 20
QUEUE_POOL_MAX=20
