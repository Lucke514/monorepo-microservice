# ──────────────────────────────────────────────────────────────────────────────
# Variables de entorno para docker-compose.
# Copia este archivo a `.env` (gitignored) y ajusta los valores:
#     cp .env.example .env
# docker-compose lo usa para interpolación (${VAR}) y como env_file de los servicios.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (compartido por main-app y worker) ──────────────────────────────
DB_PORT=5432
DB_NAME=queue_db
DB_USER=postgres
DB_PASS=postgres

# ── Queue tuning (opcional, valores por defecto en paréntesis) ──────────────────
# Tiempo máximo que un job puede estar en 'processing' antes de considerarse stale.
# Debe ser mayor que el tiempo máximo esperado de un job. Default: 300000 (5 min)
QUEUE_STALE_JOB_TIMEOUT_MS=300000

# Cada cuánto el recovery busca jobs stale. Default: 30000 (30 seg)
QUEUE_STALE_JOB_CHECK_INTERVAL_MS=30000

# Máximo de reintentos por job (puede sobreescribirse por job al hacer emit). Default: 3
QUEUE_MAX_RETRIES=3

# Tiempo máximo que el endpoint request/reply (GET /jobs/sync) espera la response
# del worker antes de devolver HTTP 408. Default: 30000 (30 seg)
QUEUE_REQUEST_TIMEOUT_MS=30000

# ── Pools de conexión (alta concurrencia) ───────────────────────────────────────
# main-app: tamaño máx. de los pools del productor (TypeORM enqueue + reply waiter). Default: 20
QUEUE_POOL_MAX=20
# worker: conexiones por instancia del worker (controla su concurrencia de procesamiento). Default: 20
QUEUE_MAX_CONNECTIONS=20
# OJO: presupuesto total ≈ Nworkers×(QUEUE_MAX_CONNECTIONS+1) + (2×QUEUE_POOL_MAX+1).
# Debe caber en el max_connections de Postgres (ver command en docker-compose, 200).
#
# Con PgBouncer (ver docker-compose), los POOLS van por pgbouncer y solo los
# clientes LISTEN van directos a Postgres. El routing se hace en docker-compose
# (DB_HOST=pgbouncer, DB_LISTEN_HOST=db). En local sin Docker, DB_LISTEN_HOST/PORT
# no se setean y caen a DB_HOST/DB_PORT automáticamente.
