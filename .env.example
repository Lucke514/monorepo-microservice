# ── PostgreSQL (compartido por main-app y worker) ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=queue_db
DB_USER=postgres
DB_PASS=postgres

# ── main-app ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Queue tunning (opcional, valores por defecto en paréntesis) ─────────────────
# Tiempo máximo que un job puede estar en 'processing' antes de considerarse stale.
# Debe ser mayor que el tiempo máximo esperado de un job. Default: 300000 (5 min)
# QUEUE_STALE_JOB_TIMEOUT_MS=300000

# Cada cuánto el recovery busca jobs stale. Default: 30000 (30 seg)
# QUEUE_STALE_JOB_CHECK_INTERVAL_MS=30000

# Máximo de reintentos por job (puede sobreescribirse por job al hacer emit). Default: 3
# QUEUE_MAX_RETRIES=3
